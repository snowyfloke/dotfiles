# ##### #
# Shell #
# ##### #

shell zsh
shell_integration         disabled

# ########## #
# Appearance #
# ########## #
include current-theme.conf

color0                    #4f4f4f
color8                    #888888
color1                    #ff4040
color9                    #ff0000
color2                    #40ff79
color10                   #00ff00
color3                    #ffff66
color11                   #ffff00
color4                    #5cbbff
color12                   #0095ff
color5                    #ff75ff
color13                   #ff00f7
color6                    #00ffff
color14                   #00ffd5
color7                    #d9d9d9
color15                   #ffffff

url_style                 curly
# Font
font_family               JetBrainsMonoNerdFont
font_size                 12
bold_text                 yes
disable_ligatures         no
# Window Options
remember_window_size      no
initial_window_width      640
initial_window_height     480
window_padding_width      20
background_opacity        0.50
confirm_os_window_close   0
# Cursor style
cursor_shape              underline
cursor_blink              yes
cursor_trail              200
cursor_trail_decay        0.1 0.2
cursor_trail_threshold    2
# Tabs
tab_bar_style             powerline
tab_powerline_style       angled

# #################### #
# Performance Settings #
# #################### #

sync_to_monitor           no # Disable VSync to unlock unlimited terminal FPS

# ############# #
# Misc Settings #
# ############# #

enable_audio_bell         no
hide_scrollbar            yes
scrollback_lines          10000

# ########## #
# Extensions #
# ########## #
map ctrl+shift+g kitten gattino/gattino.py # Gattino, AI companion for terminal
